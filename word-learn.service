[Unit]
Description=单词学习应用 - word-learn-python
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/word-learn-python
ExecStart=/home/ubuntu/word-learn-python/start_prod.sh
Restart=always
RestartSec=5
StandardOutput=append:/home/ubuntu/word-learn-python/logs/service.log
StandardError=append:/home/ubuntu/word-learn-python/logs/service.log

[Install]
WantedBy=multi-user.target
